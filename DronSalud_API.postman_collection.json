              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Pérez\",\n  \"cedula\": \"V-87654321\",\n  \"email\": \"cliente@dronesalud.com\",\n  \"password\": \"Cliente1234!\",\n  \"telefono\": \"3011234567\",\n  \"tipo_usuario\": \"cliente\",\n  \"direccion\": \"Av. España, Edif. San Carlos\"\n}"
